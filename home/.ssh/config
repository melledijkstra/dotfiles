# Github Personal Account
# Automatically use personal ssh key when in projects folder
Match host github.com exec "pwd | grep ~/projects"
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal
  AddKeysToAgent yes
  IdentitiesOnly yes

# Github Work Account
# Automatically use work ssh key when in adidas folder
Match host github.com exec "pwd | grep ~/adidas"
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_work
  AddKeysToAgent yes

# Default Github fallback
# Fallback to the personal one
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal
  AddKeysToAgent yes

# Bitbucket Work Account
Host bitbucket.tools.3stripes.net
  HostName bitbucket.tools.3stripes.net
  User git
  IdentityFile ~/.ssh/id_ed25519_work
  AddKeysToAgent yes

# Add colima config, needed for colima + docker
Include /Users/dijksmel/.colima/ssh_config
