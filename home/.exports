#!/usr/bin/env bash

# ----- PERSONAL CONFIGURATION ------------------
export WORK_DIR="$HOME/adidas"
export PROJECTS_DIR="$HOME/projects"

# important, other files rely on this env var to find the dotfiles directory
# and import shell files from there
export DOTFILES="$PROJECTS_DIR/dotfiles"

export WORK_CHROME_PROFILE="Profile 1"
export PERSONAL_CHROME_PROFILE="Profile 2"

export GIT_AUTHOR_NAME="Melle Dijkstra"
export GIT_AUTHOR_EMAIL="melle.dykstra@gmail.com"

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  # Make Visual Studio Code the default editor.
  export EDITOR='code'
else
  # Use nano for remote sessions, as it is more likely to be available and user-friendly for quick edits.
  export EDITOR='nano'
fi

# ----- OTHER CONFIGURATION --------------------

# Compilation flags
#export ARCHFLAGS="-arch $(uname -m)"

# Enable persistent REPL history for `node`.
#export NODE_REPL_HISTORY=~/.node_history;
# Allow 32³ entries; the default is 1000.
#export NODE_REPL_HISTORY_SIZE='32768';
# Use sloppy mode by default, matching web browsers.
#export NODE_REPL_MODE='sloppy';

# Prefer US English and use UTF-8.
#export LANG='en_US.UTF-8';
#export LC_ALL='en_US.UTF-8';

# Highlight section titles in manual pages.
export LESS_TERMCAP_md="${yellow}";

# Don’t clear the screen after quitting a manual page.
export MANPAGER='less -X';

# Avoid issues with `gpg` as installed via Homebrew.
# https://stackoverflow.com/a/42265848/96656
#export GPG_TTY=$(tty);

# Hide the “default interactive shell is now zsh” warning on macOS.
#export BASH_SILENCE_DEPRECATION_WARNING=1;
